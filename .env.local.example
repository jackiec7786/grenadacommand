# Login password for the app
AUTH_PASSWORD=your_password_here

# Session HMAC secret — must be at least 32 characters
SESSION_SECRET=change_this_to_a_random_32_char_string_minimum

# AES-256 encryption key for data at rest — must be exactly 32 characters
ENCRYPTION_KEY=change_this_to_a_random_32_char_key_here

# Redis connection URL (from Redis Cloud / Vercel integration)
REDIS_URL=redis://default:<password>@redis-xxxxx.c52.us-east-1-4.ec2.cloud.redislabs.com:12365
