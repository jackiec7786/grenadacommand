# Login password for the app
AUTH_PASSWORD=your_password_here

# Session encryption secret — must be at least 32 characters, keep it secret
SESSION_SECRET=change_this_to_a_random_32_char_string_minimum

# Neon Postgres
POSTGRES_URL=postgresql://...?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://...?sslmode=require
POSTGRES_USER=...
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=...
